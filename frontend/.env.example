# ─── Backend API ───────────────────────────────────────────────────────────────
# Базовый URL бэкенда. Vite читает только переменные с префиксом VITE_.
# Пример для локальной разработки без Docker:
# VITE_API_BASE_URL=http://localhost:8080/api
# Пример для Docker (по имени сервиса не работает в браузере — нужен IP или домен):
VITE_API_BASE_URL=http://192.168.0.10:8080/api

# ─── Auth ──────────────────────────────────────────────────────────────────────
# 30 дней в миллисекундах
VITE_TOKEN_EXPIRY_MS=2592000000
