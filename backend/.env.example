# ─── Database ──────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/mafia_db
SPRING_DATASOURCE_USERNAME=mafia_admin
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=your_64_hex_chars_secret_here
JWT_EXPIRATION_MS=2592000000

# ─── Mail (dev — Mailpit) ───────────────────────────────────────────────────────
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# ─── Mail (prod — например Brevo) ─────────────────────────────────────────────
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your_brevo_login@email.com
# MAIL_PASSWORD=your_brevo_smtp_key
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true

# ─── App ───────────────────────────────────────────────────────────────────────
APP_MAIL_FROM=noreply@mafia-manager.local
APP_FRONTEND_URL=http://localhost:5173
